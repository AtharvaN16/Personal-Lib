# Supabase Config (Get these from your Supabase Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Supabase service-role key (Project Settings -> API -> service_role).
# Bypasses RLS entirely — used only by the public /share/[token] route to read one
# user's books past their normal RLS policies. Never expose as NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server-only Google Books API key (restricted to the Books API only). Used by the
# server-side book lookup route and guest catalog. Do not expose this as NEXT_PUBLIC_.
GOOGLE_BOOKS_API_KEY=your-server-google-books-api-key-here
