# Supabase Config (Get these from your Supabase Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Books API key (optional but recommended — get a free key at
# https://console.cloud.google.com/apis/credentials, enable "Books API", and restrict it by
# HTTP referrer to your domain). Without it, cover-fetching falls back to Google's shared
# unauthenticated quota, which is usually exhausted.
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here
